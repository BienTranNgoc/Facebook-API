root = true

# ──────────────────────────────────────────────
# Default for all files
# ──────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 120

# ──────────────────────────────────────────────
# YAML / YML
# ──────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ──────────────────────────────────────────────
# JSON
# ──────────────────────────────────────────────
[*.json]
indent_size = 2

# ──────────────────────────────────────────────
# JavaScript / TypeScript
# ──────────────────────────────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 4

# ──────────────────────────────────────────────
# HTML / CSS
# ──────────────────────────────────────────────
[*.{html,css}]
indent_size = 2

# ──────────────────────────────────────────────
# Shell scripts
# ──────────────────────────────────────────────
[*.sh]
indent_size = 2

# ──────────────────────────────────────────────
# Dockerfile
# ──────────────────────────────────────────────
[Dockerfile*]
indent_size = 4

# ──────────────────────────────────────────────
# Markdown
# ──────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# ──────────────────────────────────────────────
# Makefile
# ──────────────────────────────────────────────
[Makefile]
indent_style = tab

# ──────────────────────────────────────────────
# EditorConfig / INI-style configs
# ──────────────────────────────────────────────
[*.{ini,cfg,toml}]
indent_size = 4

# ──────────────────────────────────────────────
# Prometheus / Alertmanager rules
# ──────────────────────────────────────────────
[*.rules]
indent_size = 2
