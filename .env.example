# ──────────────────────────────────────────────
# Database PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_DB=fb_api_db
POSTGRES_USER=fb_api_user
POSTGRES_PASSWORD=fb_api_password
POSTGRES_HOST_PORT=5433

# ──────────────────────────────────────────────
# Django Backend API
# ──────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-local-fb-api-change-me
ALLOWED_HOSTS=localhost,0.0.0.0,127.0.0.1,testserver
KAFKA_ENABLED=true

# Admin dashboard protection
DASHBOARD_API_TOKEN=

# ──────────────────────────────────────────────
# Facebook App Credentials
# ──────────────────────────────────────────────
APP_ID=your-facebook-app-id
APP_SECRET=your-facebook-app-secret
REDIRECT_URI=https://localhost:5000/callback
PAGE_ACCESS_TOKEN=your-page-access-token
VERIFY_TOKEN=your-verify-token

# ──────────────────────────────────────────────
# Facebook Graph API
# ──────────────────────────────────────────────
FACEBOOK_API_MODE=mock
FACEBOOK_GRAPH_VERSION=v20.0
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ──────────────────────────────────────────────
# Webhook Service
# ──────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=local-verify-token
REQUIRE_WEBHOOK_SIGNATURE=false

# ──────────────────────────────────────────────
# AI Provider
# ──────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Retry Service
# ──────────────────────────────────────────────
MAX_RETRY_COUNT=3
RETRY_BACKOFF_BASE_SECONDS=1

# ──────────────────────────────────────────────
# Kafka Topics
# ──────────────────────────────────────────────
KAFKA_RAW_EVENTS_TOPIC=raw_events
KAFKA_REPLY_COMMANDS_TOPIC=reply_commands
KAFKA_SEND_RETRY_TOPIC=send_retry
KAFKA_SEND_FAILED_TOPIC=send_failed
KAFKA_DEAD_LETTER_TOPIC=dead_letter

# ──────────────────────────────────────────────
# Host Port Mappings
# ──────────────────────────────────────────────
ZOOKEEPER_HOST_PORT=2181
KAFKA_HOST_PORT=9092
KAFKA_UI_HOST_PORT=8080
KAFKA_EXPORTER_HOST_PORT=9308
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9093
GRAFANA_HOST_PORT=3004
JAEGER_HOST_PORT=16686
OPENSEARCH_HOST_PORT=9200
OPENSEARCH_PERF_HOST_PORT=9600
OPENSEARCH_DASHBOARDS_HOST_PORT=5601
BACKEND_API_HOST_PORT=3000
WEBHOOK_HOST_PORT=3001
CORE_SERVICE_HOST_PORT=3002
RETRY_SERVICE_HOST_PORT=3003

# ──────────────────────────────────────────────
# OpenSearch
# ──────────────────────────────────────────────
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
